<?xml version="1.0" encoding="utf-8"?>
<Programs xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.staubli.com/robotics/VAL3/Program/2">
  <Program name="readData">
    <Parameters xmlns="http://www.staubli.com/robotics/VAL3/Param/1">
      <Parameter name="x_UdpSocket" type="sio" xsi:type="element" use="reference" />
      <Parameter name="x_nData" type="num" xsi:type="array" use="reference" />
      <Parameter name="x_bNewData" type="bool" xsi:type="element" use="reference" />
      <Parameter name="x_bError" type="bool" xsi:type="element" use="reference" />
    </Parameters>
    <Locals>
      <Local name="l_nSioReadBytes" type="num" xsi:type="array" size="1" />
      <Local name="l_nSioReadBytesBis" type="num" xsi:type="array" size="1" />
    </Locals>
    <Code><![CDATA[begin
  x_bNewData = false
  x_bError = false

  // Read from UDP socket
  l_nSioReadBytes = sioGet(x_UdpSocket, x_nData)

  if(l_nSioReadBytes == size(x_nData))
    // Successfully read a full message
    x_bNewData = true
    return
  elseIf (l_nSioReadBytes > 0)
    // Message of wrong size received, error
    logMsg("ros2_server::readData : message of wrong size received", 2)
    x_bError = true
    return
  endIf

  if (x_bNewData)
    // If we got something, try to read again to clear the buffer
    l_nSioReadBytesBis = sioGet(x_UdpSocket, x_nData)
  endIf

  if (l_nSioReadBytesBis > 0 and l_nSioReadBytesBis != size(x_nData))
    // Message of wrong size received, error
    logMsg("ros2_server::readData : message of wrong size received (2)", 2)
    x_bError = true
    return
  endIf

  // Check for errors
  if(l_nSioReadBytes == -1 or l_nSioReadBytesBis == -1)
    // Communication error of some kind
    x_bError = true
    logMsg("ros2_server::readData : Communication error", 2)
  elseIf(l_nSioReadBytes == 0)
    // No data available in buffer
    x_bError = false
    // logMsg("ros2_server::readData : No data available", 2)
  else
    // Communication error of some kind
    x_bError = true
    logMsg("ros2_server::readData : unexpected packet size", 2)
  endIf
end]]></Code>
  </Program>
</Programs>
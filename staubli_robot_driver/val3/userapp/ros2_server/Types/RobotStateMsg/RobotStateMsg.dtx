<?xml version="1.0" encoding="utf-8"?>
<Database xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.staubli.com/robotics/VAL3/Data/2">
  <Datas>
    <!-- Initialization flag -->
    <Data name="bIsInitialized" access="public" xsi:type="array" type="bool" size="1">
      <Value key="0" value="true" />
    </Data>

    <!-- Standard message header -->
    <Data name="header" access="public" xsi:type="array" type="MessageHeader" size="1"/>

    <!-- Robot state information -->
    <Data name="robotState" access="public" xsi:type="array" type="RobotState" size="1" />

    <!-- Serialized message -->
    <Data name="nSerializedData" access="public" xsi:type="array" type="num" size="1"/>

  </Datas>
</Database>
